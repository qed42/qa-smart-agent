# ─────────────────────────────────────────────────────────────
# QA Smart Agent — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Environment & secrets (NEVER commit these) ──
.env
.env.local
.env.production
.env.staging
.env.*
*.key
*.pem
secrets.json
config.secret.*

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ── Node.js (backend wrapper) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── QA Agent outputs (don't commit generated files) ──
*.csv
#*.md
*.docx
qa_output_*
schroff_*
queue_*
*_test_cases*
*_builder.js

# ── Logs ──
logs/
*.log
usage_log.json
usage_log.csv

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

.DS_Store